# ---- Copy these into Railway → your service → Variables ----

# Postgres: added automatically when you attach a Railway Postgres plugin.
# Railway injects DATABASE_URL for you — you usually don't paste this by hand.
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Gmail sending (REQUIRED to send the confirmation email)
GMAIL_USER=kealohavolleyball@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword   # Google App Password, NOT your normal password

# Where leads get sent after submitting (REQUIRED)
REGISTRATION_URL=https://www.sportsengine.com/your-registration-link

# Meta tracking (OPTIONAL)
META_PIXEL_ID=                # e.g. 1234567890123456  — enables the browser pixel
META_CAPI_TOKEN=              # Conversions API token — enables server-side tracking

# Protects the /api/leads.csv export (OPTIONAL but recommended)
ADMIN_TOKEN=pick-a-long-random-string

# Set to "require" only if your Postgres needs SSL.
# Railway's internal DATABASE_URL does NOT — leave blank.
PGSSL=
